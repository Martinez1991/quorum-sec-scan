# syntax=docker/dockerfile:1

# ─────────────────────────────────────────────────────────────────────────────
# quorum:full — orchestrator + every bundled scanner. Self-contained for CI.
#
# SUPPLY-CHAIN NOTE (DESIGN §12): the version tags below are PINNED VERSIONS for
# readability. Before shipping to production, replace each mutable tag with an
# immutable @sha256:<digest> and verify release checksums. A scanner image is
# part of YOUR trust boundary.
# ─────────────────────────────────────────────────────────────────────────────

ARG TRIVY_VERSION=0.71.2
ARG GRYPE_VERSION=v0.114.0
ARG SYFT_VERSION=v1.11.0
ARG DOCKLE_VERSION=0.4.14
ARG KICS_VERSION=v2.1.3
ARG KUBESCAPE_VERSION=v3.0.8
ARG CHECKOV_VERSION=3.2.300

# Pull prebuilt scanner binaries from their official images, PINNED BY DIGEST
# (the tag is kept alongside for readability). Re-resolve digests when bumping a
# version: docker buildx imagetools inspect <image>:<tag> --format '{{.Manifest.Digest}}'
FROM aquasec/trivy:${TRIVY_VERSION}@sha256:f5d0e600ecda7449e2a9b272805aef698631d3bb3f3a739a750de2c6819acdc9 AS trivy
FROM checkmarx/kics:${KICS_VERSION}-alpine@sha256:8b191adbd156038cfbc163fd1ab1b210c839bd9e065777287eadc8d267a60b9d AS kics

# ── Build the quorum binary ──────────────────────────────────────────────────
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 go build -trimpath \
    -ldflags "-s -w -X main.version=${VERSION}" \
    -o /out/quorum ./cmd/quorum

# ── Assemble the runtime image ───────────────────────────────────────────────
FROM alpine:3.20
ARG GRYPE_VERSION
ARG SYFT_VERSION
ARG DOCKLE_VERSION
ARG KUBESCAPE_VERSION
ARG CHECKOV_VERSION

RUN apk add --no-cache ca-certificates bash curl tar python3 py3-pip git docker-cli

# quorum + bundled crosswalks
COPY --from=build /out/quorum /usr/local/bin/quorum
COPY crosswalk /opt/quorum/crosswalk

# Trivy (binary lives at /usr/local/bin/trivy in the official image)
COPY --from=trivy /usr/local/bin/trivy /usr/local/bin/trivy

# KICS: copy binary + its query assets together so they sit side-by-side
# (KICS discovers ./assets next to the executable).
COPY --from=kics /app/bin/ /usr/local/bin/

# Grype + Syft via the official anchore installers (checksum-verified by the script).
RUN curl -sSfL https://raw.githubusercontent.com/anchore/grype/main/install.sh \
      | sh -s -- -b /usr/local/bin ${GRYPE_VERSION} && \
    curl -sSfL https://raw.githubusercontent.com/anchore/syft/main/install.sh \
      | sh -s -- -b /usr/local/bin ${SYFT_VERSION}

# Pre-cache grype's vulnerability DB into the image so the first scan works
# offline and never hits "failed to load vulnerability db: database does not
# exist". The DB is frozen as of build time — rebuild to refresh it, or set
# GRYPE_DB_AUTO_UPDATE=true at runtime (needs network) to update on the fly.
ENV GRYPE_DB_CACHE_DIR=/opt/grype/db \
    GRYPE_DB_AUTO_UPDATE=false
RUN grype db update && grype db status

# Dockle from GitHub release (verify checksum).
RUN set -eux; \
    ver="${DOCKLE_VERSION}"; \
    curl -sSfL -o /tmp/dockle.tgz \
      "https://github.com/goodwithtech/dockle/releases/download/v${ver}/dockle_${ver}_Linux-64bit.tar.gz"; \
    curl -sSfL -o /tmp/dockle.sha256 \
      "https://github.com/goodwithtech/dockle/releases/download/v${ver}/dockle_${ver}_checksums.txt"; \
    grep "Linux-64bit.tar.gz" /tmp/dockle.sha256 | awk '{print $1"  /tmp/dockle.tgz"}' | sha256sum -c -; \
    tar -xzf /tmp/dockle.tgz -C /usr/local/bin dockle; \
    rm -f /tmp/dockle.tgz /tmp/dockle.sha256

# Kubescape via official installer.
RUN curl -sSfL https://github.com/kubescape/kubescape/releases/download/${KUBESCAPE_VERSION}/kubescape-ubuntu-latest \
      -o /usr/local/bin/kubescape && chmod +x /usr/local/bin/kubescape || \
    curl -sSfL https://raw.githubusercontent.com/kubescape/kubescape/master/install.sh | bash

# Checkov in an isolated venv.
RUN python3 -m venv /opt/checkov && \
    /opt/checkov/bin/pip install --no-cache-dir "checkov==${CHECKOV_VERSION}" && \
    ln -s /opt/checkov/bin/checkov /usr/local/bin/checkov

WORKDIR /work
ENTRYPOINT ["quorum"]
CMD ["--help"]
